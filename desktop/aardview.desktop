[Desktop Entry]
Name=AardView
Comment=Simple image and video viewer (widget version)
Exec=aardview %F
Icon=aardview
Type=Application
Categories=Graphics;Viewer;
MimeType=image/bmp;image/gif;image/jpeg;image/png;image/tiff;image/x-bmp;image/x-pcx;image/x-portable-bitmap;image/x-portable-graymap;image/x-portable-pixmap;image/x-psd;image/x-xcf;image/x-xpm;image/svg+xml;image/webp;video/x-msvideo;video/mp4;video/ogg;video/quicktime;video/x-matroska;video/x-ms-wmv;video/webm;
Terminal=false
